// ── ACTIVE PROGRAM (this is what gets sent to Gemini) ──────────────────────
// You can have multiple functions here. Each one tests a different construct.

// 1. Simple function (no control flow)
func add(a: int, b: int) -> int {
  return a + b;
}

// 2. If/else (Gemini needs a phi node at the merge block)
func max_val(a: int, b: int) -> int {
  int result = 0;
  if (a > b) {
    result = a;
  } else {
    result = b;
  }
  return result;
}

// 3. While loop (Gemini needs phi nodes at the loop header)
func sum_to(n: int) -> int {
  int i = 0;
  int total = 0;
  while (i < n) {
    total = total + i;
    i = i + 1;
  }
  return total;
}

// 4. For loop
func multiply(n: int) -> int {
  int result = 0;
  for (int i = 0; i < n; i = i + 1) {
    result = result + n;
  }
  return result;
}
